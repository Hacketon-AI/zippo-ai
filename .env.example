# =========================
# App
# =========================
APP_NAME=personal-ai-assistant
APP_ENV=development

# =========================
# PostgreSQL
# =========================
POSTGRES_USER=changeme
POSTGRES_PASSWORD=changeme
POSTGRES_DB=personal_ai
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Active DB URL read by api/app/core/config.py (async driver)
DATABASE_URL=postgresql+asyncpg://changeme:changeme@postgres:5432/personal_ai

# =========================
# Qdrant
# =========================
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION=personal_ai_memory

# =========================
# Ollama (do NOT expose publicly)
# =========================
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_DEFAULT_MODEL=qwen3:4b
OLLAMA_TIMEOUT_SECONDS=60
OLLAMA_EMBED_MODEL=nomic-embed-text

# =========================
# Ollama tuning
# =========================
# Qwen3 non-thinking mode: temperature 0.7, top_p 0.8 (per model card).
OLLAMA_NUM_CTX=8192
OLLAMA_TEMPERATURE=0.7
OLLAMA_TOP_P=0.8
OLLAMA_REPEAT_PENALTY=1.1
OLLAMA_THINK=false

# =========================
# OpenRouter (optional cloud LLM, disabled by default)
# =========================
USE_OPENROUTER=false
OPENROUTER_API_KEY=
OPENROUTER_MODEL=qwen/qwen3-235b-a22b

# =========================
# CORS
# =========================
CORS_ORIGINS=http://localhost:5173,http://localhost:3001

# =========================
# Rate limiting
# =========================
RATE_LIMIT_ENABLED=true
CHAT_RATE_LIMIT=10/minute

# =========================
# Web UI
# =========================
VITE_API_BASE_URL=http://localhost:8000
