# =========================
# App
# =========================
APP_NAME=personal-ai-assistant
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=info

# =========================
# PostgreSQL
# =========================
POSTGRES_USER=changeme
POSTGRES_PASSWORD=changeme
POSTGRES_DB=personal_ai
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Active DB URL read by api/app/core/config.py (async driver)
DATABASE_URL=postgresql+asyncpg://changeme:changeme@postgres:5432/personal_ai

# =========================
# Qdrant
# =========================
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION=personal_ai_memory

# =========================
# Ollama (do NOT expose publicly)
# =========================
# Active variables read by api/app/core/config.py
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_DEFAULT_MODEL=qwen3:4b
OLLAMA_TIMEOUT_SECONDS=60

# Reserved for later phases (embedding/RAG)
OLLAMA_EMBED_MODEL=nomic-embed-text

# Deprecated (kept here only as a migration note, not read by the app)
# OLLAMA_HOST=ollama
# OLLAMA_PORT=11434
# OLLAMA_MODEL=qwen3:4b

# =========================
# External API fallback (optional, disabled by default)
# =========================
EXTERNAL_FALLBACK_ENABLED=false
EXTERNAL_FALLBACK_PROVIDER=none
EXTERNAL_FALLBACK_API_KEY=
EXTERNAL_FALLBACK_TIMEOUT_SECONDS=60

# =========================
# CORS
# =========================
CORS_ORIGINS=http://localhost:5173,http://localhost:3001

# =========================
# Web UI
# =========================
VITE_API_BASE_URL=http://localhost:8000
